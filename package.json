{
  "name": "nova",
  "version": "1.0.0",
  "description": "A high-performance Discord Bot & Activity RPG Monorepo built with Sapphire and Mongoose",
  "author": "SharifPoetra",
  "license": "MIT",
  "type": "module",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "bot:dev": "npm run dev -w apps/bot",
    "activity:dev": "npm run dev -w apps/activity",
    "build": "npm run build -w packages/database && npm run build -w apps/bot",
    "start": "node apps/bot/dist/index.js",
    "start:bot": "node apps/bot/dist/index.js",
    "start:activity": "node apps/activity/dist/index.js",
    "api:dev": "npm run dev -w apps/api",
    "dev": "npm run build && npm run start",
    "format": "prettier --write \"{apps,packages}/**/*.ts\"",
    "lint": "eslint \"{apps,packages}/**/*.ts\" --fix",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules apps/*/dist packages/*/dist",
    "clean:dist": "rm -rf apps/*/dist packages/*/dist",
    "test": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SharifPoetra/nova.git"
  },
  "bugs": {
    "url": "https://github.com/SharifPoetra/nova/issues"
  },
  "keywords": ["discord-bot", "sapphire-framework", "monorepo", "activity-rpg", "typescript", "mongoose"],
  "homepage": "https://github.com/SharifPoetra/nova#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  }
}
