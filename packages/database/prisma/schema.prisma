generator client {
  provider = "prisma-client"
  output   = "./generated-client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id // Discord User ID
  balance   Int      @default(1000) // Saldo awal
  exp       Int      @default(0)
  level     Int      @default(1)
  lastDaily DateTime? // Untuk fitur daily reward nanti
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
